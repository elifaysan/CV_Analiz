# CV Analiz - LLM API Anahtarları
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
# copy .env.example .env

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Groq (https://console.groq.com) - Ücretsiz tier mevcut
GROQ_API_KEY=

# Ollama (yerel, ücretsiz) - ChatGPT benzeri sohbet için
# Kurulum: ollama run mistral  (veya: llama3.1, qwen2.5)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
